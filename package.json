{
  "name": "webp-squeeze",
  "version": "1.0.0",
  "description": "Локальный минималистичный конвертер изображений в WebP",
  "author": "Valentin Bryukhantsev",
  "license": "MIT",
  "main": "src/main.js",
  "homepage": "https://github.com/valedol190387/webp-squeeze",
  "repository": {
    "type": "git",
    "url": "https://github.com/valedol190387/webp-squeeze.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --arm64",
    "dist:win": "electron-builder --win --x64",
    "icon": "node scripts/make-icon.js"
  },
  "build": {
    "appId": "com.valentin.webpsqueeze",
    "productName": "WebP Squeeze",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.graphics-design",
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "title": "WebP Squeeze"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WebP Squeeze"
    }
  },
  "dependencies": {
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "sharp"
    ]
  }
}

{
  "name": "webp-squeeze",
  "version": "1.1.1",
  "description": "Локальный минималистичный конвертер изображений в WebP",
  "author": "Valentin Bryukhantsev",
  "license": "MIT",
  "main": "src/main.js",
  "homepage": "https://github.com/valedol190387/webp-squeeze",
  "repository": {
    "type": "git",
    "url": "https://github.com/valedol190387/webp-squeeze.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --arm64",
    "dist:win": "electron-builder --win --x64",
    "icon": "node scripts/make-icon.js"
  },
  "build": {
    "appId": "com.valentin.webpsqueeze",
    "productName": "WebP Squeeze",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.graphics-design",
      "icon": "assets/icon.icns",
      "artifactName": "WebP-Squeeze-${version}-macOS-arm64.${ext}",
      "identity": null
    },
    "dmg": {
      "title": "WebP Squeeze",
      "background": "assets/dmg-background.png",
      "window": {
        "width": 600,
        "height": 520
      },
      "iconSize": 100,
      "iconTextSize": 13,
      "contents": [
        {
          "x": 150,
          "y": 285,
          "type": "file"
        },
        {
          "x": 450,
          "y": 285,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 300,
          "y": 430,
          "type": "file",
          "path": "assets/READ ME FIRST (macOS).txt"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WebP Squeeze",
      "artifactName": "WebP-Squeeze-${version}-Windows-Installer.${ext}"
    },
    "portable": {
      "artifactName": "WebP-Squeeze-${version}-Windows-Portable.${ext}"
    }
  },
  "dependencies": {
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "sharp"
    ]
  }
}
